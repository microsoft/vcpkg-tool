{
  "js/ts.tsdk.path": "./vcpkg-artifacts/node_modules/typescript/lib",
  "eslint.workingDirectories": [
    {
      "changeProcessCWD": true,
      "directory": "./vcpkg-artifacts",
    }
  ],
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "eslint.format.enable": true,
  "files.eol": "\n",
  "files.associations": {
    "any": "cpp",
    "array": "cpp",
    "atomic": "cpp",
    "bit": "cpp",
    "*.tcc": "cpp",
    "bitset": "cpp",
    "cctype": "cpp",
    "chrono": "cpp",
    "clocale": "cpp",
    "cmath": "cpp",
    "codecvt": "cpp",
    "complex": "cpp",
    "condition_variable": "cpp",
    "cstdarg": "cpp",
    "cstddef": "cpp",
    "cstdint": "cpp",
    "cstdio": "cpp",
    "cstdlib": "cpp",
    "cstring": "cpp",
    "ctime": "cpp",
    "cwchar": "cpp",
    "cwctype": "cpp",
    "deque": "cpp",
    "list": "cpp",
    "map": "cpp",
    "set": "cpp",
    "unordered_map": "cpp",
    "unordered_set": "cpp",
    "vector": "cpp",
    "exception": "cpp",
    "algorithm": "cpp",
    "functional": "cpp",
    "iterator": "cpp",
    "memory": "cpp",
    "memory_resource": "cpp",
    "numeric": "cpp",
    "optional": "cpp",
    "random": "cpp",
    "ratio": "cpp",
    "regex": "cpp",
    "string": "cpp",
    "string_view": "cpp",
    "system_error": "cpp",
    "tuple": "cpp",
    "type_traits": "cpp",
    "utility": "cpp",
    "fstream": "cpp",
    "future": "cpp",
    "initializer_list": "cpp",
    "iomanip": "cpp",
    "iosfwd": "cpp",
    "iostream": "cpp",
    "istream": "cpp",
    "limits": "cpp",
    "mutex": "cpp",
    "new": "cpp",
    "ostream": "cpp",
    "shared_mutex": "cpp",
    "sstream": "cpp",
    "stdexcept": "cpp",
    "streambuf": "cpp",
    "thread": "cpp",
    "cinttypes": "cpp",
    "typeindex": "cpp",
    "typeinfo": "cpp",
    "variant": "cpp",
    "__bit_reference": "cpp"
  },
  "C_Cpp.default.compileCommands": [
      "${workspaceFolder}/out/build/Win-x64-Debug/compile_commands.json",
      "${workspaceFolder}/out/build/Win-x64-Debug-WithArtifacts/compile_commands.json",
      "${workspaceFolder}/out/build/Win-x64-Debug-NoAnalyze/compile_commands.json",
      "${workspaceFolder}/out/build/Win-x64-Debug-Official/compile_commands.json",
      "${workspaceFolder}/out/build/Win-x64-Release/compile_commands.json",
      "${workspaceFolder}/out/build/Win-x64-Release-Official/compile_commands.json",
      "${workspaceFolder}/out/build/windows-ci/compile_commands.json",
      "${workspaceFolder}/out/build/linux-with-artifacts/compile_commands.json",
      "${workspaceFolder}/out/build/linux-debug/compile_commands.json",
      "${workspaceFolder}/out/build/linux-ci/compile_commands.json",
      "${workspaceFolder}/out/build/linux-codespaces/compile_commands.json",
      "${workspaceFolder}/out/build/macos/compile_commands.json",
      "${workspaceFolder}/out/build/macos-ci/compile_commands.json"
  ]
}
